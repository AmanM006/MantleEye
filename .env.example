# ============================================
# MANTLEYE — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ----- Mantle Network -----
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_PRIVATE_KEY=your_private_key_here
MANTLE_CHAIN_ID=5003

# Contract addresses (populated after deployment)
TRADE_LOGGER_ADDRESS=
SIGNAL_ANCHOR_ADDRESS=
AGENT_REGISTRY_ADDRESS=

# ----- Bybit -----
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=true

# ----- AI -----
ANTHROPIC_API_KEY=your_anthropic_api_key

# ----- Alerts -----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# ----- Database -----
DATABASE_URL=postgresql://mantleye:mantleye_pass@localhost:5432/mantleye
POSTGRES_USER=mantleye
POSTGRES_PASSWORD=mantleye_pass
POSTGRES_DB=mantleye

# ----- Redis -----
REDIS_URL=redis://localhost:6379

# ----- API -----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ----- Frontend -----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
